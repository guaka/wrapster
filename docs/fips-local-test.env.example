WRAPSTER_PUBLIC_PORT=15542
WRAPSTER_IMAGE=wrapster-local-fips-test
FIPS_REF=v0.3.0
FIPS_SIDECAR_IMAGE=ghcr.io/guaka/wrapster-fips-sidecar:v0.3.0
WRAPSTER_CONNECTOR_IMAGE=ghcr.io/guaka/wrapster:latest
RUST_LOG=info

FIPS_LOCAL_TEST_CONF_FILE=/conf.toml

FIPS_DATA_UID=10001
FIPS_DATA_GID=10001
FIPS_PUBLIC_NSEC=nsec1wemwy5pukcyf764dkd9m9uuy8dj5wrsquf28rsn295slsm7ynrhq7xa72j
FIPS_HOME_NSEC=nsec1ueqj2ggnyxeenvhrzpcas7vemg7yr0ld2qyjsyrk7kwre78fgjmq8272aj
FIPS_PUBLIC_NPUB=npub10pd3fsdyx6j9eu3aj8gkq6ewjraenzcl35psdskft5qycd3xsa2s5upnzg
FIPS_HOME_NPUB=npub1gy07h4z4rtv4vt6xmq9z5y3zl58k6qug8phtvm6glvhppf99g9vqp26rp0

FIPS_PUBLIC_ADDR=fips-public:8443
FIPS_PUBLIC_ALIAS=public-wrapster
FIPS_PUBLIC_TRANSPORT=tcp

# Outbound-only from home: leave FIPS_HOME_ADDR empty on the public side.
# Requires the bind-mounted entrypoint (via_nostr + Nostr discovery) and
# outbound internet from containers to default FIPS Nostr relays.
FIPS_HOME_ADDR=
FIPS_HOME_ALIAS=home-media
FIPS_HOME_TRANSPORT=udp

MEDIA_CONNECTOR_BASE_URL=http://home-media.fips:22000
MEDIA_CONNECTOR_TOKEN=connector-token-test
# Dedicated media smoke identity (not a FIPS sidecar key).
MEDIA_SMOKE_NSEC=nsec1pcpn9sjf4dtn003n0w2jxt9r3tgd8p4xd625nscx7cjr05w6ulxq432qsn
MEDIA_SMOKE_NPUB=npub1ecjw8jlqpkt3edkhdlj7apk6pcd2r0kgmrnvyu7nk83af09a327q8m6dsv
MEDIA_GRANT_PUBKEYS=ce24e3cbe00d971cb6d76fe5ee86da0e1aa1bec8d8e6c273d3b1e3d4bcbd8abc
MEDIA_AUTH_MAX_AGE=60s
MEDIA_TRANSPORT_LABEL=fips

CONNECTOR_SHARED_TOKEN=connector-token-test
CONNECTOR_ALLOWED_CIDRS=fd00::/8,127.0.0.1/32,::1/128
CONNECTOR_ADMIN_PUBKEYS=
CONNECTOR_SETUP_PORT=22201
CONNECTOR_LISTEN_ADDR=:22000
CONNECTOR_SETUP_LISTEN_ADDR=:22001
CONNECTOR_SETUP_AUTH_MAX_AGE=60s
CONNECTOR_HTTP_TIMEOUT=30s

JELLYFIN_BASE_URL=
JELLYFIN_API_KEY=
PLEX_BASE_URL=
PLEX_TOKEN=

# Optional manual override for /media/api/status (smoke generates NIP-98 from MEDIA_SMOKE_NSEC by default):
# MEDIA_STATUS_AUTHORIZATION=

# Optional host port overrides for FIPS transports (defaults: 2121/udp, 8443/tcp):
# FIPS_PUBLIC_TCP_PORT=8443
# FIPS_PUBLIC_UDP_PORT=2121
# FIPS_HOME_TCP_PORT=8443
# FIPS_HOME_UDP_PORT=2121

# Keep these bind variables aligned with service-side listener ports unless you are doing
# a custom transport experiment:
# FIPS_PUBLIC_TCP_BIND=0.0.0.0:8443
# FIPS_PUBLIC_UDP_BIND=0.0.0.0:2121
# FIPS_HOME_TCP_BIND=0.0.0.0:8443
# FIPS_HOME_UDP_BIND=0.0.0.0:2121
