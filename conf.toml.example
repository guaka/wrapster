owner_npub = "npub1999example"
additional_relays = ["wss://nip42.trustroots.org"]
access_rule = {"nip05_domain": "trustroots.org"}


[proxy_group.hospex]
urls = ["https://www.trustroots.org",
  "https://hitchwiki.org",
  "https://nomadwiki.org",
  "https://en.wikivoyage.org",
  "https://wiki.trustroots.org",
]

[wiki.nomadwiki]
origin = "https://nomadwiki.org"
label = "Nomadwiki"
summary = "Travel wiki"
wiki_path = "/wiki"
wiki_api_path = "/api.php"
wiki_load_path = "/index.php"
wiki_main_page_path = "/wiki/en/Main_Page"
wiki_main_page_title = "Main_Page"
proxy_route = "nomadwiki.org"
status = "active"
audience = "community"

[wiki.wikivoyage]
origin = "https://en.wikivoyage.org"
label = "Wikivoyage"
summary = "Free worldwide travel guide"
wiki_path = "/wiki"
wiki_api_path = "/w/api.php"
wiki_load_path = "/w/index.php"
wiki_main_page_path = "/wiki/Main_Page"
wiki_main_page_title = "Main Page"
proxy_route = "en.wikivoyage.org"
status = "active"
audience = "community"

[proxy_group.media]
urls = ["wireguard_jellyfin", "wireguard_plex"]
additional_access_rule = ["nostr_follow"]
